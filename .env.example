# ═══════════════════════════════════════════════════════════════
# Überseehub Marketing Dashboard — Environment Variables
# ═══════════════════════════════════════════════════════════════
# All API routes use 'use server' + NEXT_PUBLIC_ prefix.
# Fallback to old names for backwards compatibility with Vercel.
#
# For AWS Amplify: use the NEXT_PUBLIC_ names below.
# For Vercel (current): old names without prefix still work.
# ═══════════════════════════════════════════════════════════════

# ── NextAuth ─────────────────────────────────────────────────
# Read automatically by NextAuth — no process.env needed in code
NEXTAUTH_URL=https://marketing-dashboard-psi-murex.vercel.app

# Read via process.env in [...nextauth]/route.ts
NEXT_PUBLIC_NEXTAUTH_SECRET=

# ── Google OAuth (Login) ──────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_SECRET=

# ── Google Ads API ────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_DEVELOPER_TOKEN=
NEXT_PUBLIC_GOOGLE_REFRESH_TOKEN=
NEXT_PUBLIC_GOOGLE_ADS_CUSTOMER_ID=8929447460
NEXT_PUBLIC_GOOGLE_LOGIN_CUSTOMER_ID=3320073191

# ── Meta Ads API ──────────────────────────────────────────────
# Expires after 60 days — renew regularly in Meta Business Manager
NEXT_PUBLIC_META_ACCESS_TOKEN=
NEXT_PUBLIC_META_AD_ACCOUNT_ID=act_791386393546392

# ── finCRM (Baufi Sales) ──────────────────────────────────────
NEXT_PUBLIC_FINCRM_ACCESS_TOKEN=

# ── Retool (Sanierung Leads) ──────────────────────────────────
NEXT_PUBLIC_RETOOL_WORKFLOW_KEY=
