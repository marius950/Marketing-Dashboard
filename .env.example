# ════════════════════════════════════════════════════════════════
# Überseehub Marketing Dashboard — Environment Variables
# ════════════════════════════════════════════════════════════════
#
# VERCEL:     Variablen direkt in Vercel Settings eintragen
#             → GOOGLE_DEVELOPER_TOKEN als "Sensitive" markieren
#
# AWS AMPLIFY: Variablen in Amplify Console eintragen (ohne Prefix).
#              Die amplify.yml schreibt sie vor dem Build in
#              .env.production — Next.js kann sie dann serverseitig lesen.
#              KEIN NEXT_PUBLIC_ nötig, da alle Variablen nur in
#              API Routes (server-side) verwendet werden.
# ════════════════════════════════════════════════════════════════

# ── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_SECRET=            # openssl rand -base64 32
NEXTAUTH_URL=https://marketing-dashboard-psi-murex.vercel.app

# ── Google OAuth (Login) ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Ads API ────────────────────────────────────────────
GOOGLE_DEVELOPER_TOKEN=     # Als "Sensitive" in Vercel markieren!
GOOGLE_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=8929447460
GOOGLE_LOGIN_CUSTOMER_ID=3320073191

# ── Meta Ads API ──────────────────────────────────────────────
META_ACCESS_TOKEN=          # Läuft nach 60 Tagen ab!
META_AD_ACCOUNT_ID=act_791386393546392

# ── finCRM ────────────────────────────────────────────────────
FINCRM_ACCESS_TOKEN=

# ── Retool ────────────────────────────────────────────────────
RETOOL_WORKFLOW_KEY=
